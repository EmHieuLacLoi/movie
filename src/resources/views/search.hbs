<div class="container mt-5">
  <table class="table table-dark table-hover table-custom">
    <thead>
      <tr>
        <th>TÊN</th>
        <th>NĂM RA MẮT</th>
        <th>LỐI TẮT</th>
      </tr>
    </thead>
    <tbody class="table-content">
      {{#each movie}}
        <tr>
          <td>
            <div class="movie-info">
              <img src="{{poster}}" alt="{{name}}" />
              <div class="movie-names">
                <div class="primary-name"><a
                    href="/movie/{{slug}}"
                  >{{name}}</a></div>
                <div class="origin-name text-sm text-gray-600"><a
                    href="/movie/{{slug}}"
                  >{{origin_name}}</a></div>
              </div>
            </div>
          </td>
          <td>{{year}}</td>
          <td><button
              type="button"
              class="btn btn-outline-light btn-sm btn-add"
              data-bs-toggle="modal"
              data-bs-target="#staticBackdrop"
              data-name= "{{name}}"
              data-slug="{{slug}}"
              data-poster="{{poster}}"
              data-year="{{year}}"
            >Thêm</button></td>
        </tr>
      {{/each}}
    </tbody>
  </table>

  <!-- Modal -->
  <div
    class="modal fade"
    id="staticBackdrop"
    data-bs-backdrop="static"
    data-bs-keyboard="false"
    tabindex="-1"
    aria-labelledby="staticBackdropLabel"
    aria-hidden="true"
  >
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h1 class="modal-title fs-5" id="staticBackdropLabel">Thông báo</h1>
          <button
            type="button"
            class="btn-close"
            data-bs-dismiss="modal"
            aria-label="Close"
          ></button>
        </div>
        <div class="modal-body">
          <h5>Bạn có muốn thêm lối tắt vào trang chủ không ?</h5>
        </div>
        <div class="modal-footer">
          <button
            type="button"
            class="btn btn-secondary"
            data-bs-dismiss="modal"
          >Không</button>
          <button
            type="button"
            class="btn btn-primary btn-yes"
            data-bs-dismiss="modal"
          >Có</button>
        </div>
      </div>
    </div>
  </div>

  {{!-- Xem thêm --}}
  <div class="text-center my-3">
    <button id="load-more" class="btn btn-outline-light">Xem thêm</button>
  </div>

</div>

<script>
  // Hàm gắn sự kiện "click" cho nút .btn-add
  function attachAddButtonListeners() {
    const btnAdd = document.querySelectorAll('.btn-add');
    btnAdd.forEach(btn => {
      btn.addEventListener('click', e => {
        const objData = {};
        objData['name'] = e.target.getAttribute('data-name');
        objData['slug'] = e.target.getAttribute('data-slug');
        objData['poster'] = e.target.getAttribute('data-poster');
        objData['year'] = e.target.getAttribute('data-year');

        const btnYes = document.querySelector('.btn-yes');
        btnYes.addEventListener('click', () => {
          // Tạo và submit form ẩn
          const form = document.createElement('form');
          form.method = 'post';
          form.action = `/add-shortcut?_method=PUT`;
          form.style.display = 'none';

          for (const [key, value] of Object.entries(objData)) {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = key;
            input.value = value;
            form.appendChild(input);
          }

          const submitButton = document.createElement('button');
          submitButton.type = 'submit';
          form.appendChild(submitButton);
          document.body.appendChild(form);

          // Submit form
          form.submit();
        });
      });
    });
  }

  // Gọi hàm attachAddButtonListeners lần đầu tiên khi trang load
  attachAddButtonListeners();

  // JavaScript - Thêm logic nút "Xem thêm"
  let currentPage = {{currentPage}};
  let keyword = "{{keyword}}";
  let hasMore = {{hasMore}};

  const moreBtn = document.getElementById('load-more');
  const tbody = document.querySelector('.table-content');

  if (!hasMore) {
    moreBtn.style.display = 'none';
  } else {
    moreBtn.addEventListener('click', async () => {
      moreBtn.disabled = true;
      moreBtn.innerText = "Đang tải...";
      try {
        currentPage++;
        const response = await fetch(`/search?search=${encodeURIComponent(keyword)}&page=${currentPage}&ajax=true`);
        const data = await response.json();

        if (data.status === 'success') {
          const newMovies = data.movie;
          
          newMovies.forEach(movie => {
            const safeName = movie.name.replace(/"/g, '&quot;');
            const row = `
              <tr>
                <td>
                  <div class="movie-info">
                    <img src="${movie.poster}" alt="${safeName}" class="movie-poster" />
                    <div class="movie-names">
                      <div class="primary-name"><a href="/movie/${movie.slug}">${movie.name}</a></div>
                      <div class="origin-name text-sm text-gray-600"><a href="/movie/${movie.slug}">${movie.origin_name}</a></div>
                    </div>
                  </div>
                </td>
                <td>${movie.year}</td>
                <td>
                  <button
                    type="button"
                    class="btn btn-outline-light btn-sm btn-add"
                    data-bs-toggle="modal"
                    data-bs-target="#staticBackdrop"
                    data-name="${safeName}"
                    data-slug="${movie.slug}"
                    data-poster="${movie.poster}"
                    data-year="${movie.year}"
                  >Thêm</button>
                </td>
              </tr>
            `;
            tbody.innerHTML += row;
          });

          // Gọi lại hàm attachAddButtonListeners để gắn sự kiện cho các nút mới
          attachAddButtonListeners();

          if (!data.hasMore) {
            moreBtn.style.display = 'none';
          }
        } else {
          alert(data.message || "Lỗi tải thêm phim");
          currentPage--; 
        }
      } catch (error) {
         console.error("Error loading more movies: ", error);
         alert("Có lỗi xảy ra khi tải thêm phim");
         currentPage--;
      } finally {
         moreBtn.disabled = false;
         moreBtn.innerText = "Xem thêm";
      }
    });
  }
</script>
